# ============================================
# 昕动智能后端环境变量配置示例
# ============================================
# 使用说明：
# 1. 复制此文件为 .env.backend
# 2. 修改下面的值为实际配置
# 3. 启动后端时加载这些环境变量
# ============================================

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=xindong
DB_USER=xindong
DB_PASSWORD=xindong123

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT 配置
JWT_SECRET=change-this-to-a-random-secret-key-in-production

# 微信小程序配置
WECHAT_APPID=your-wechat-appid
WECHAT_SECRET=your-wechat-secret

# Druid 数据库监控（生产环境建议禁用）
DRUID_ENABLED=true
DRUID_USERNAME=admin
DRUID_PASSWORD=change-this-password

# MQTT 配置
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# 干预引擎配置
INTERVENTION_ENGINE_URL=http://localhost:4001

# CORS 配置（生产环境使用具体域名，不要用 *）
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3080

# 服务器配置
SERVER_PORT=8080

# 日志级别
LOGGING_LEVEL=INFO
